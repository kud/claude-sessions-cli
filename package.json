{
  "name": "@kud/claude-sessions-cli",
  "version": "2.0.1",
  "description": "TUI session manager for Claude Code",
  "homepage": "https://kud.github.io/claude-sessions-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/kud/claude-sessions-cli.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-sessions": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "publish:next": "npm publish --tag next"
  },
  "dependencies": {
    "ink": "7.0.1",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
